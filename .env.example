# Copy this file to .env and set your values.
# SUPERUSER_PASSWORD is required for the default superuser (username: ritesha).
SUPERUSER_PASSWORD=your_secure_password_here

# Supabase (required for database)
# Get these from Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Or use SUPABASE_KEY if you prefer (service role key recommended for full access)
# SUPABASE_KEY=your-service-role-key

# Set to false only if you get SSL certificate errors (e.g. self-signed / corporate proxy)
# SUPABASE_VERIFY_SSL=false
